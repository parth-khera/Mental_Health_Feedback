# ── Client-side (Firebase SDK) ──────────────────────────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=           # paste your apiKey here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=       # paste your authDomain here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=        # paste your projectId here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=    # paste your storageBucket here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID= # paste your messagingSenderId here
NEXT_PUBLIC_FIREBASE_APP_ID=            # paste your appId here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=    # paste your measurementId here

# ── Server-side (Firebase Admin SDK) ────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Open the downloaded JSON and copy the values below

FIREBASE_PROJECT_ID=        # paste project_id from service account JSON
FIREBASE_CLIENT_EMAIL=      # paste client_email from service account JSON
FIREBASE_PRIVATE_KEY=       # paste private_key from service account JSON (keep the \n characters)
